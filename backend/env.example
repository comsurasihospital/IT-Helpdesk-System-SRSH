# ============================================================
# IT Helpdesk System - Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้ถูกต้อง
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=5000

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=it_helpdesk
DB_POOL_LIMIT=10

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# --- LINE ---
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_LIFF_ID=your_liff_id
LINE_IT_GROUP_ID=your_it_group_id

# --- File Upload ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# --- Frontend URL (สำหรับ CORS) ---
FRONTEND_URL=http://localhost:3000

# --- Hospital ---
HOSPITAL_NAME=โรงพยาบาลของคุณ
